# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# MongoDB Atlas connection string.
# Use mongodb+srv:// if your network resolves DNS TXT records.
# If TXT lookups fail (corporate / restricted DNS), use the non-SRV form with
# explicit shard hosts: mongodb://user:pass@shard-00-00.xxx:27017,shard-00-01.xxx:27017,shard-00-02.xxx:27017/db?ssl=true&authSource=admin&retryWrites=true&w=majority
MONGODB_URI=

# Groq AI (https://console.groq.com)
GROQ_API_KEY=

# NextAuth (run: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Optional — added later
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
